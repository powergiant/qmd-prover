{
  "name": "qmd-prover",
  "version": "0.1.0",
  "description": "A Quarto-based agentic mathematical proof workflow",
  "type": "module",
  "bin": {
    "qmd-prover": "skills/qmd-prover/scripts/qmd-prover.js"
  },
  "files": [
    "skills/qmd-prover/scripts",
    "skills/qmd-prover/references"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npm run build && tsc --project tsconfig.fixtures.json && node --import tsx --test tests/*.test.ts",
    "prepare": "npm run build",
    "install:tool": "npm install --global .",
    "install:skill": "tsx tooling/install-skill.ts --local --claude",
    "install:skill:global": "tsx tooling/install-skill.ts --global --claude",
    "install:skill:codex": "tsx tooling/install-skill.ts --local --codex",
    "install:skill:codex:global": "tsx tooling/install-skill.ts --global --codex"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
